.custom-tabbar {
    position: fixed;
    bottom: calc(constant(safe-area-inset-bottom) + 14px);
    bottom: calc(env(safe-area-inset-bottom) + 14px);
    left: 0;
    width: 100%;
    background: transparent;
    box-shadow: none;
    z-index: 9999;
    display: flex;
    justify-content: center;
    pointer-events: auto;
}

.tab-pill {
    display: flex;
    justify-content: space-around;
    align-items: center;
    height: 74px;
    width: calc(100% - 52rpx);
    max-width: 720rpx;
    padding: 0 12rpx;
    box-sizing: border-box;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    border: 1rpx solid rgba(217, 225, 236, 0.95);
    box-shadow: 0 12rpx 28rpx rgba(27, 63, 110, 0.12);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    pointer-events: auto;
}

.tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    color: #888;
    font-size: 12px;
    transition: color 0.3s ease;
}

.tab-item.active {
    color: #007bff; /* Active tab color */
}

.tab-icon {
    font-size: 20px;
    margin-bottom: 4rpx;
}

.tab-text {
    font-size: 10px;
}

/* Center "Publish" button styling */
.center-item {
    position: relative;
    bottom: 0;
    width: auto;
    height: auto;
    border-radius: 50%;
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: none;
    color: #007bff;
}

.publish-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56rpx;
    height: 56rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #4ba5ff 0%, #2e7feb 100%);
    box-shadow: 0 8rpx 18rpx rgba(52, 126, 218, 0.35);
}

.publish-plus {
    font-size: 38rpx;
    line-height: 1;
    color: #fff;
}

.publish-text {
    font-size: 20rpx;
    margin-top: 4rpx;
    color: #4a5568;
}