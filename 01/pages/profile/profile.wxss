@import "../../templates/tabbar.wxss";

.container {
    padding-top: 70px; /* Adjust based on tabbar height (50px) + safe area inset + potential shadow */
    padding-bottom: 20px; /* Add some bottom padding for overall content */
    min-height: 100vh; /* Ensure container takes full height */
    background-color: #f8f8f8; /* Light background for the page */
}

.profile-header {
    background-color: #fff;
    padding: 20px;
    margin-bottom: 15px;
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
}

.user-info-card {
    display: flex;
    align-items: center;
    padding: 15px 0;
}

.login-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #007bff;
    color: #fff;
    border-radius: 10px;
    padding: 15px 20px;
    width: 100%;
    box-sizing: border-box;
    font-size: 16px;
    border: none;
}

.avatar-placeholder {
    font-size: 40px;
    margin-bottom: 10px;
    background-color: #e0e0e0;
    border-radius: 50%;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
}

.login-text {
    font-size: 16px;
    margin-top: 10px;
}

.avatar-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    margin-right: 15px;
    border: 2px solid #eee;
}

.avatar-wrap image {
    width: 100%;
    height: 100%;
}

.user-detail {
    display: flex;
    flex-direction: column;
}

.user-name {
    font-size: 20px;
    font-weight: bold;
    color: #333;
}

.user-id {
    font-size: 14px;
    color: #666;
    margin-top: 5px;
}

.profile-section {
    background-color: #fff;
    margin: 0 15px 15px 15px;
    padding: 15px;
    border-radius: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
}

.section-title {
    font-size: 18px;
    font-weight: bold;
    color: #333;
    margin-bottom: 15px;
    padding-bottom: 10px;
    border-bottom: 1px solid #eee;
}

.bookmarks-list {
    /* Styles for the list of bookmarks */
}

.empty-state {
    text-align: center;
    color: #999;
    padding: 20px 0;
    font-size: 14px;
}

.bookmark-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid #f5f5f5;
    font-size: 15px;
    color: #555;
}

.bookmark-item:last-child {
    border-bottom: none;
}

.bookmark-date {
    font-size: 13px;
    color: #999;
}
