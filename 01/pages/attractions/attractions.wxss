/* 01/pages/attractions/attractions.wxss */
@import "../home/home.wxss";

.attr-card {
    background: #ffffff;
    border-radius: 28rpx;
    overflow: hidden;
    margin-bottom: 34rpx;
    box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.05);
}

.attr-img-box {
    position: relative;
    width: 100%;
    height: 340rpx;
}

.attr-img {
    width: 100%;
    height: 100%;
    background: #eef1f3; /* 图片加载前的占位色 */
}

.attr-tag-box {
    position: absolute;
    left: 20rpx;
    bottom: 20rpx;
    display: flex;
    gap: 10rpx;
}

.attr-tag {
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    font-size: 20rpx;
    padding: 6rpx 16rpx;
    border-radius: 8rpx;
    backdrop-filter: blur(4px);
}

.attr-info {
    padding: 24rpx;
}

.attr-name {
    display: block;
    font-size: 34rpx;
    font-weight: 700;
    color: #111827;
}

.attr-desc {
    display: block;
    margin-top: 10rpx;
    font-size: 24rpx;
    color: #6b7280;
    line-height: 1.6;
}

.attr-tips {
    margin-top: 16rpx;
    background: #fdf2f2;
    padding: 16rpx;
    border-radius: 12rpx;
    display: flex;
    gap: 10rpx;
}

.tips-icon { font-size: 24rpx; }
.tips-text { font-size: 22rpx; color: #b91c1c; flex: 1; }