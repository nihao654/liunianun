@import "../../templates/tabbar.wxss"; /* Import the common tabbar styles */

.container {
    /* Ensure the container takes full height and has background */
    min-height: 100vh;
    background-color: #f8f8f8;
}

.message-header-padding {
    /* This class will push down the content below the fixed tab bar */
    height: 70px; /* Adjust based on tabbar height (50px) + safe area inset + potential shadow */
}

.page-content {
    padding-bottom: 20px; /* Add some bottom padding for overall content */
}

.notice-list {
    padding: 0 10rpx;
}

.notice-card {
    background: #ffffff;
    border-radius: 28rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    position: relative;
    box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.03);
    display: flex;
    flex-direction: column;
}

.unread-style {
    background: #fdfdfd;
    border-left: 8rpx solid #58c796;
}

.card-tag {
    display: inline-block;
    padding: 4rpx 16rpx;
    border-radius: 8rpx;
    font-size: 22rpx;
    color: #666;
    width: fit-content;
    margin-bottom: 20rpx;
}

.title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12rpx;
}

.notice-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
}

.notice-time {
    font-size: 24rpx;
    color: #bbb;
}

.notice-desc {
    font-size: 28rpx;
    color: #777;
    line-height: 1.6;
}

.red-dot {
    position: absolute;
    top: 30rpx;
    right: 30rpx;
    width: 14rpx;
    height: 14rpx;
    background: #ff5252;
    border-radius: 50%;
}

.empty-box {
    text-align: center;
    padding-top: 200rpx;
    color: #999;
}