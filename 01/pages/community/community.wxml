<import src="../../templates/tabbar.wxml" />

<view class="community-page">
  <!-- 顶级流光动态背景层 -->
  <view class="fluid-stage" aria-hidden="true">
    <view class="ambient-orb orb-mint"></view>
    <view class="ambient-orb orb-yellow"></view>
    <view class="ambient-orb orb-cyan"></view>
    <view class="glass-wash-overlay"></view>
  </view>

  <scroll-view class="community-scroll" scroll-y="true" show-scrollbar="false">
    <view class="page-shell">
      <view class="hero-copy">
        <text class="eyebrow">Community Feed</text>
        <text class="hero-title">你好，{{welcomeCountryZh}}</text>
        <text class="hero-subtitle">{{subtitle}}</text>
        <text class="hero-desc">{{description}}</text>

        <view class="journey-pill">
          <view class="journey-dot dot-home"></view>
          <view class="journey-dot dot-community"></view>
          <view class="journey-dot dot-publish"></view>
          <text class="journey-text">{{journeyNote}}</text>
        </view>
      </view>

      <view class="stats-row">
        <block wx:for="{{stats}}" wx:key="id">
          <view class="stat-card acrylic-card">
            <text class="stat-value">{{item.value}}</text>
            <text class="stat-label">{{item.label}}</text>
          </view>
        </block>
      </view>

      <view class="avatar-shell acrylic-card">
        <view class="avatar-shell-head">
          <text class="avatar-shell-title">旅人头像</text>
          <text class="avatar-shell-meta">soft online glow</text>
        </view>

        <scroll-view class="avatar-strip" scroll-x="true" show-scrollbar="false">
          <view class="avatar-row">
            <block wx:for="{{avatars}}" wx:key="id">
              <view class="avatar-item" bindtap="onAvatarTap" data-name="{{item.name}}">
                <view class="avatar-bubble {{item.tone}}">
                  <view class="avatar-ring"></view>
                  <text class="avatar-initials">{{item.initials}}</text>
                </view>
                <text class="avatar-name">{{item.name}}</text>
              </view>
            </block>
          </view>
        </scroll-view>
      </view>

      <view class="feature-card acrylic-card">
        <view class="feature-head">
          <view class="feature-author-badge">
            <text class="feature-author-initial">A</text>
          </view>
          <view class="feature-author-copy">
            <text class="feature-author-name">{{featuredPost.author}}</text>
            <text class="feature-author-meta">{{featuredPost.role}} · {{featuredPost.time}}</text>
          </view>
          <view class="compose-button" bindtap="onComposeTap">
            <text class="compose-button-text">发布</text>
          </view>
        </view>

        <text class="feature-title">{{featuredPost.title}}</text>
        <text class="feature-body">{{featuredPost.body}}</text>

        <view class="feature-image-shell">
          <image class="feature-image" src="{{featuredPost.image}}" mode="aspectFill" />
          <view class="feature-image-wash"></view>
        </view>

        <view class="feature-meta-row">
          <text class="feature-location">{{featuredPost.location}}</text>
          <text class="feature-light">{{featuredPost.light}}</text>
        </view>

        <view class="feature-tags">
          <block wx:for="{{featuredPost.tags}}" wx:key="*this">
            <text class="feature-tag" bindtap="onTagTap" data-tag="{{item}}">{{item}}</text>
          </block>
        </view>

        <view class="feature-actions">
          <view class="feature-action feature-action-primary {{featuredPost.isLiked ? 'feature-action-liked' : ''}}" bindtap="onLikeTap">
            <text class="feature-action-icon">{{featuredPost.isLiked ? '♥' : '♡'}}</text>
            <text class="feature-action-text">{{featuredPost.likesText}}</text>
          </view>

          <view class="feature-action feature-action-secondary" bindtap="onActionTap" data-action="comment">
            <text class="feature-action-icon secondary-icon">✦</text>
            <text class="feature-action-text secondary-text">{{featuredPost.commentsText}}</text>
          </view>

          <view class="feature-action feature-action-secondary" bindtap="onActionTap" data-action="save">
            <text class="feature-action-icon secondary-icon">⌂</text>
            <text class="feature-action-text secondary-text">{{featuredPost.savesText}}</text>
          </view>

          <view class="feature-action feature-action-secondary" bindtap="onActionTap" data-action="share">
            <text class="feature-action-icon secondary-icon">↗</text>
            <text class="feature-action-text secondary-text">Share</text>
          </view>
        </view>
      </view>

      <view class="bottom-gap"></view>
    </view>
  </scroll-view>

  <template is="tabbar" data="{{ activeTab: 'community' }}" />
</view>