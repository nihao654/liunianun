@import "../../templates/tabbar.wxss";

page {
  background: #f8f9fa;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", "Helvetica Neue", sans-serif;
}

/* =========================================
   大体 ?AI 伴游互动 ?(AI Hero Container)
   ========================================= */
.ai-hero-container {
  position: relative;
  width: 100%;
  height: 560rpx;
  margin-bottom: 60rpx;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  overflow: visible;
  background: radial-gradient(circle at 50% 30%, #e0f7fa 0%, #f1f8e9 40%, #ffffff 100%);
  box-shadow: 0 20rpx 50rpx rgba(224, 247, 250, 0.5), inset 0 4rpx 10rpx rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.hero-text-area {
  z-index: 10;
  margin-top: 60rpx;
  text-align: center;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #2c3e50;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 10rpx rgba(255, 255, 255, 0.9);
}

.elephant-interaction-area {
  position: absolute;
  top: 190rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.elephant-interaction-area.hidden {
  transform: translate(-145rpx, 40rpx) rotate(0deg);
}
.elephant-interaction-area.revealed {
  transform: translate(-60rpx, 0) rotate(0deg);
}

.elephant-wrapper {
  position: relative;
  z-index: 5;
  width: 320rpx;
  height: 320rpx;
  animation: float 4s ease-in-out infinite;
}

.elephant-tooltip {
  position: absolute;
  left: 250rpx;
  top: 78rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  z-index: 30;
  opacity: 0;
  white-space: nowrap;
  transform: translateX(18rpx) translateY(8rpx) scale(0.96);
  pointer-events: none;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  backdrop-filter: blur(10px);
  transform-origin: left center;
}

.elephant-tooltip.show {
  opacity: 1;
  transform: translateX(0) translateY(0) scale(1);
  pointer-events: auto;
}

.elephant-tooltip text {
  font-size: 24rpx;
  color: #4a5568;
  line-height: 1.5;
  display: block;
}

.tooltip-arrow {
  position: absolute;
  left: -12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 12rpx solid rgba(255, 255, 255, 0.95);
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}


.safety-card {
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #72cfaa 0%, #52b58f 45%, #63c89e 100%);
  box-shadow: 0 12rpx 30rpx rgba(76, 177, 137, 0.24);
  padding: 24rpx;
}

.safety-card::after {
  content: "";
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  right: -28rpx;
  top: 30rpx;
  background: rgba(255, 255, 255, 0.14);
}

.safety-header,
.safety-level-row,
.safety-text,
.safety-date {
  position: relative;
  z-index: 1;
}

.safety-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.safety-title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
}

.safety-more {
  display: inline-block;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  transform: translateY(-4rpx);
}

.safety-level-row {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.safety-level {
  color: #ffffff;
  font-size: 26rpx;
}

.shield-icon {
  color: #ffffff;
  font-size: 30rpx;
}

.safety-text {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.95);
  font-size: 24rpx;
  line-height: 1.5;
}

.safety-date {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
}

.custom-tabbar {
  bottom: calc(constant(safe-area-inset-bottom) + 4px) !important;
  bottom: calc(env(safe-area-inset-bottom) + 4px) !important;
  z-index: 9999;
}

.feature-block {
  width: 100%;
  margin-top: 36rpx;
}

.feature-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 40rpx 10rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateY(-4rpx);
}

.feature-icon-shell {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-grid .feature-item:nth-child(2) .feature-icon-shell {
  background-image: linear-gradient(135deg, #E8FAEE 0%, #BEEFD0 100%) !important;
}

.feature-grid .feature-item:nth-child(2) .feature-icon {
  color: #2F80ED;
}

.feature-grid .feature-item:nth-child(3) .feature-icon-shell {
  background-image: linear-gradient(135deg, #FDFDFD 0%, #FFF8E1 100%) !important;
  border-radius: 50%;
}

.feature-grid .feature-item:nth-child(3) .feature-icon {
  color: #1565C0;
}

.health-cross-mark {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}

.health-cross-fill {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 24rpx;
  height: 24rpx;
  transform: translate(-50%, -50%);
}

.health-cross-h,
.health-cross-v {
  position: absolute;
  left: 50%;
  top: 50%;
  background: #1565C0;
  border-radius: 2rpx;
  transform: translate(-50%, -50%);
}

.health-cross-h {
  width: 24rpx;
  height: 8rpx;
}

.health-cross-v {
  width: 8rpx;
  height: 24rpx;
}

.health-cross-glint {
  position: absolute;
  right: 8rpx;
  top: 9rpx;
  width: 8rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #FFD700;
  transform: rotate(-18deg);
}

.feature-grid .feature-item:nth-child(4) .feature-icon-shell {
  background-image: linear-gradient(135deg, #FCE4EC 0%, #F8BBD0 100%) !important;
}

.feature-grid .feature-item:nth-child(4) .feature-icon {
  color: #C2185B;
}

.feature-grid .feature-item:nth-child(5) .feature-icon-shell {
  background-image: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%) !important;
}

.feature-grid .feature-item:nth-child(5) .feature-icon {
  color: #1976D2;
}

.feature-grid .feature-item:nth-child(6) .feature-icon-shell {
  background-image: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%) !important;
}

.feature-grid .feature-item:nth-child(6) .feature-icon {
  color: #7B1FA2;
}

.feature-grid .feature-item:nth-child(7) .feature-icon-shell {
  background-image: linear-gradient(135deg, #E0F7FA 0%, #B2EBF2 100%) !important;
}

.feature-grid .feature-item:nth-child(7) .feature-icon {
  color: #0097A7;
}

.feature-grid .feature-item:nth-child(8) .feature-icon-shell {
  background-image: linear-gradient(135deg, #FFFDE7 0%, #FFECB3 100%) !important;
}

.feature-grid .feature-item:nth-child(8) .feature-icon {
  color: #FBC02D;
}

.feature-icon {
  color: #374151;
  font-size: 40rpx;
}

.feature-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #374151;
}

.emergency-row {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  gap: 16rpx;
}

.emergency-card {
  flex: 1;
  border-radius: 20rpx;
  padding: 20rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.08);
  transform: translateY(-4rpx);
}

.embassy {
  background: #edf1f6;
}

.hotline {
  background: #f2edf5;
}

.emergency-icon {
  font-size: 42rpx;
  margin-bottom: 8rpx;
}

.en-text {
  font-size: 20rpx;
  color: #6b7280;
}

.zh-text {
  margin-top: 4rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}




